# Required
export GRAFANA_CLOUD_PROM_URL="XXX"
export GRAFANA_CLOUD_PROM_USERNAME="XXX"          # Metrics instance ID
export GRAFANA_CLOUD_OTLP_URL="XXX"
export GRAFANA_CLOUD_OTLP_USERNAME="XXX"          # OTLP instance ID (usually same as above)
export GRAFANA_CLOUD_API_KEY="XXX"            # API token: MetricsPublisher + TracesPublisher scopes

# Optional — enables pod log forwarding to Loki
export GRAFANA_CLOUD_LOKI_URL="XXX"
export GRAFANA_CLOUD_LOKI_USERNAME="XXX"

# Optional — printed in setup output for convenience
export GRAFANA_CLOUD_STACK_URL="XXX"

export GCP_PROJECT="XXX"
export GCP_REGION="XXX"
export ARTIFACT_REGISTRY="XXX"
export GKE_CLUSTER="XXX"

# Pyroscope (profiling)
export GRAFANA_CLOUD_PYROSCOPE_URL="XXX"
export GRAFANA_CLOUD_PYROSCOPE_USERNAME="XXX"

# Fleet management (Alloy remote config)
export GRAFANA_FLEET_URL="XXX"
export GRAFANA_FLEET_USERNAME="XXX"

# Grafana Sigil SDK — structured LLM generation telemetry
# Token requires sigil:write scope in Grafana Cloud access policy
export SIGIL_ENDPOINT="XXX"
export SIGIL_AUTH_TENANT_ID="XXX"   # Grafana Cloud stack/instance ID
export SIGIL_AUTH_TOKEN="XXX"   # API token with sigil:write scope