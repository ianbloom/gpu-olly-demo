{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "GKE GPU AI Observability",
  "description": "LLM inference metrics from OpenLIT + DCGM GPU metrics",
  "tags": ["ai", "gpu", "llm", "openlit", "gke"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(otel_gen_ai_requests_total[1m])",
          "legendFormat": "{{model}} – {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P50 / P95 / P99 Inference Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(otel_gen_ai_request_duration_ms_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(otel_gen_ai_request_duration_ms_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(otel_gen_ai_request_duration_ms_bucket[1m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Token Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(otel_gen_ai_tokens_total{type=\"prompt\"}[1m])",
          "legendFormat": "prompt tokens/s"
        },
        {
          "expr": "rate(otel_gen_ai_tokens_total{type=\"completion\"}[1m])",
          "legendFormat": "completion tokens/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}} – {{Hostname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "GPU Memory Used (MiB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}} used"
        },
        {
          "expr": "DCGM_FI_DEV_FB_FREE",
          "legendFormat": "GPU {{gpu}} free"
        }
      ]
    },
    {
      "id": 6,
      "title": "GPU Power Draw (W)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{gpu}} – {{Hostname}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "watt" } }
    },
    {
      "id": 7,
      "title": "GPU Temperature (°C)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(otel_gen_ai_requests_total{status!=\"success\"}[1m])",
          "legendFormat": "errors/s – {{status}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Active Pods",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count(kube_pod_status_ready{namespace=\"ai-demo\",condition=\"true\"})",
          "legendFormat": "Ready pods"
        }
      ]
    },
    {
      "id": 10,
      "title": "Total Requests (last hour)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 24, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(otel_gen_ai_requests_total[1h])",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 11,
      "title": "Total Tokens (last hour)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 24, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(otel_gen_ai_tokens_total[1h])",
          "legendFormat": "tokens"
        }
      ]
    }
  ]
}
